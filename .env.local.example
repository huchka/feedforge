# Tier 1 (host-direct) environment.
# Copy to .env.local (gitignored). Backend reads via pydantic-settings (FEEDFORGE_ prefix).

FEEDFORGE_DB_HOST=localhost
FEEDFORGE_DB_PORT=5432
FEEDFORGE_DB_NAME=feedforge
FEEDFORGE_DB_USER=feedforge
FEEDFORGE_DB_PASSWORD=feedforge

FEEDFORGE_REDIS_HOST=localhost
FEEDFORGE_REDIS_PORT=6379

FEEDFORGE_DEBUG=true

# LLM provider — set GOOGLE_API_KEY in your shell, not here, to avoid accidental commits
# FEEDFORGE_LLM_PROVIDER=gemini
# FEEDFORGE_LLM_MODEL=gemini-2.5-flash
# FEEDFORGE_GCP_PROJECT_ID=
