apiVersion: v1
kind: Secret
metadata:
  name: notification-credentials
  namespace: feedforge
  labels:
    app.kubernetes.io/name: daily-digest
    app.kubernetes.io/component: worker
    app.kubernetes.io/part-of: feedforge
type: Opaque
stringData:
  # Slack — fill in if using digest_provider=slack
  NOTIFICATION_WEBHOOK_URL: "CHANGE_ME"
  # LINE — fill in if using digest_provider=line
  LINE_CHANNEL_TOKEN: "CHANGE_ME"
  LINE_USER_ID: "CHANGE_ME"
