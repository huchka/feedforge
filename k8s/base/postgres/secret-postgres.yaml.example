apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: feedforge
  labels:
    app.kubernetes.io/name: postgres
    app.kubernetes.io/component: database
    app.kubernetes.io/part-of: feedforge
type: Opaque
stringData:
  POSTGRES_USER: feedforge
  POSTGRES_PASSWORD: CHANGE_ME
  POSTGRES_DB: feedforge
