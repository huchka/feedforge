apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: feedforge
  labels:
    app.kubernetes.io/name: cloudsql-proxy
    app.kubernetes.io/component: database-proxy
    app.kubernetes.io/part-of: feedforge
type: Opaque
stringData:
  # Cloud SQL credentials — get password from: terraform output -raw cloudsql_db_password
  POSTGRES_USER: feedforge
  POSTGRES_PASSWORD: CHANGE_ME
  POSTGRES_DB: feedforge
